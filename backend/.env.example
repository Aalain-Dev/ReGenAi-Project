# Copy this file to .env and fill in real values. Never commit .env.
# Tip: no spaces around the "=" sign.

# Server
PORT=3000
NODE_ENV=development
# Number of worker processes (cores). 1 = single process. Capped at CPU count.
WEB_CONCURRENCY=1

# Database (MongoDB connection string)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>/<dbname>

# Auth — generate a strong secret, e.g. `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-secret

# CORS — comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173

# AI provider
GROQ_API_KEY=your-groq-api-key

# Business rules
ALLOWED_REPORTS_PER_DAY=3
